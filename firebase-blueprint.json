{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login time" }
      },
      "required": ["uid", "email"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "Stores user's bookmarked verses.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's user ID" },
        "verseRef": { "type": "string", "description": "Verse reference (e.g., John 3:16)" },
        "text": { "type": "string", "description": "The verse text" },
        "translation": { "type": "string", "description": "The translation used" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When bookmarked" }
      },
      "required": ["uid", "verseRef", "text"]
    },
    "History": {
      "title": "Search History",
      "description": "Stores user's emotion search history.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's user ID" },
        "emotion": { "type": "string", "description": "The emotion typed or selected" },
        "response": { "type": "string", "description": "The AI generated response" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When searched" }
      },
      "required": ["uid", "emotion"]
    },
    "Forum": {
      "title": "Forum",
      "description": "A forum category.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Forum title" },
        "description": { "type": "string", "description": "Forum description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When created" }
      },
      "required": ["title"]
    },
    "Thread": {
      "title": "Thread",
      "description": "A forum thread.",
      "type": "object",
      "properties": {
        "forumId": { "type": "string", "description": "Parent forum ID" },
        "title": { "type": "string", "description": "Thread title" },
        "authorUid": { "type": "string", "description": "Author user ID" },
        "authorName": { "type": "string", "description": "Author display name" },
        "isAnonymous": { "type": "boolean", "description": "Whether to show as anonymous" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When created" }
      },
      "required": ["forumId", "title", "authorUid"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in a thread.",
      "type": "object",
      "properties": {
        "threadId": { "type": "string", "description": "Parent thread ID" },
        "content": { "type": "string", "description": "Post content" },
        "authorUid": { "type": "string", "description": "Author user ID" },
        "authorName": { "type": "string", "description": "Author display name" },
        "isAnonymous": { "type": "boolean", "description": "Whether to show as anonymous" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When created" }
      },
      "required": ["threadId", "content", "authorUid"]
    },
    "PrayerRequest": {
      "title": "Prayer Request",
      "description": "A prayer request on the wall.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Prayer request content" },
        "authorUid": { "type": "string", "description": "Author user ID" },
        "authorName": { "type": "string", "description": "Author display name" },
        "isAnonymous": { "type": "boolean", "description": "Whether to show as anonymous" },
        "prayCount": { "type": "integer", "description": "Number of people praying" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When created" }
      },
      "required": ["content", "authorUid"]
    },
    "Note": {
      "title": "Note",
      "description": "A user's personal note with AI analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner's user ID" },
        "title": { "type": "string", "description": "Note title" },
        "content": { "type": "string", "description": "Note content" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time" }
      },
      "required": ["userId", "title", "content"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User bookmarks"
    },
    "/history/{historyId}": {
      "schema": "History",
      "description": "User emotion search history"
    },
    "/forums/{forumId}": {
      "schema": "Forum",
      "description": "Forums"
    },
    "/forums/{forumId}/threads/{threadId}": {
      "schema": "Thread",
      "description": "Threads in a forum"
    },
    "/forums/{forumId}/threads/{threadId}/posts/{postId}": {
      "schema": "Post",
      "description": "Posts in a thread"
    },
    "/prayer_requests/{requestId}": {
      "schema": "PrayerRequest",
      "description": "Prayer requests"
    },
    "/prayer_requests/{requestId}/prayers/{userId}": {
      "schema": "object",
      "description": "Tracks which users have prayed for this request"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User personal notes"
    }
  }
}
